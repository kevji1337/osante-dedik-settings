# =============================================================================
# Git Ignore - Security Hardening Project
# Описание: Исключение секретов и чувствительных файлов из git
# =============================================================================

# =============================================================================
# Secrets & Environment Files
# =============================================================================
*.env
.env
.env.local
.env.production
telegram.env
restic.env
backup.env
*.env.example

# =============================================================================
# Credentials & Keys
# =============================================================================
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk

# =============================================================================
# Backup Files
# =============================================================================
*.backup
*.bak
*.old
backup/
backups/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
/var/log/

# =============================================================================
# Docker & Container Data
# =============================================================================
docker-compose.override.yml
prometheus_data/
alertmanager_data/
grafana_data/

# =============================================================================
# IDE & Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.temp

# =============================================================================
# System Files
# =============================================================================
/etc/
/opt/
/var/
